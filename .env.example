# =================================================================
# 🔑 API KEYS & SECRETS
# =================================================================
myAPIKey = "your_api_key_here"
googleAPIKey = "your_google_api_key_here"
YOUTUBE_API_KEY = "your_youtube_api_key_here"
GEMINI_API_KEY = "your_gemini_api_key_here"

# =================================================================
# 🤖 LLM CONFIGURATION (OpenAI)
# =================================================================
# Main Models (Tutor, Coding, Math, Quiz)
OPENAI_MODEL = "gpt-4o-mini"
OPENAI_MAX_TOKENS = 8192
OPENAI_TEMPERATURE = 0.1

# Supervisor Model (Routing logic)
OPENAI_SUPERVISOR_MODEL = "gpt-4o-mini"
OPENAI_SUPERVISOR_MAX_TOKENS = 1024
OPENAI_SUPERVISOR_TEMPERATURE = 0.0

# Embedding Model
EMBEDDING_MODEL_NAME = "models/production/bge-m3-v3"

# Chunking Strategy
CHUNK_STRATEGY = "recursive"  # Options: recursive, timestamp_150_50, timestamp_90_30, semantic, parent_child_180s_45s
SEMANTIC_EMBEDDING_PROVIDER = "openai"  # "openai" (text-embedding-3-large) or "bge" (fine-tuned BGE-M3)

# =================================================================
# 📦 DATABASE & CACHE
# =================================================================
# PostgreSQL (Supabase)
DATABASE_URL = "postgresql://username:password@host:port/database?sslmode=require"

# Redis Stack local trong Docker Compose
REDIS_URL = "redis://redis-stack:6379/0"

# MongoDB (Cũ - giữ lại nếu cần)
mongodb_url = "mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp"

# =================================================================
# 🛡️ SECURITY & JWT
# =================================================================
JWT_SECRET = "your_jwt_secret_key_here_min_32_chars"
JWT_ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30
REFRESH_TOKEN_EXPIRE_DAYS = 7

# =================================================================
# 📁 DIRECTORIES & PATHS
# =================================================================
PUQ_DATA_DIR = "artifacts/data"
PUQ_CHUNKS_DIR = "artifacts/chunks"
PUQ_VECTOR_DB_DIR = "artifacts/database_semantic"
PUQ_VIDEOS_DIR = "artifacts/videos"
PUQ_DATA_EXTRACTION_DIR = "artifacts/data_extraction"
TRANSNET_V2_PATH = "path/to/TransNetV2"
