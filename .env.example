myAPIKey = ""
googleAPIKey = ""
YOUTUBE_API_KEY = ""
mongodb_url = "mongodb+srv://[username:password@]host1[:port1][,host2[:port2],...]/databaseName[?options]"
PUQ_DATA_DIR = "artifacts/data"
PUQ_CHUNKS_DIR = "artifacts/chunks"
PUQ_VECTOR_DB_DIR = "artifacts/database_semantic"
PUQ_VIDEOS_DIR = "artifacts/videos"
PUQ_DATA_EXTRACTION_DIR = "artifacts/data_extraction"
OPENAI_MODEL = "gpt-5-mini"
OPENAI_SUPERVISOR_MODEL = "gpt-5-mini"
OPENAI_MAX_TOKENS = "2048"
OPENAI_SUPERVISOR_MAX_TOKENS = "512"

# Redis Stack semantic cache
REDIS_URL = "redis://localhost:6379/0"
SEMANTIC_CACHE_ENABLED = "True"
SEMANTIC_CACHE_BACKEND = "redis_stack"
SEMANTIC_CACHE_EMBEDDING_MODEL = "text-embedding-3-small"
SEMANTIC_CACHE_VECTOR_DIM = "1536"
SEMANTIC_CACHE_TOP_K = "5"
SEMANTIC_CACHE_STRONG_THRESHOLD = "0.95"
SEMANTIC_CACHE_HYBRID_THRESHOLD = "0.90"
SEMANTIC_CACHE_KEYWORD_OVERLAP = "0.55"
SEMANTIC_CACHE_TTL_SECONDS = "86400"
SEMANTIC_CACHE_PREWARM_ENABLED = "True"
SEMANTIC_CACHE_PREWARM_LIMIT = "1000"

# Docker/RAG runtime
RAG_DEVICE = "auto"
RAG_RETRIEVER_K = "40"
RAG_RETRIEVER_FETCH_K = "80"
RAG_RETRIEVER_LAMBDA = "0.7"
RAG_RERANK_TOP_K = "10"
HF_HOME = "/app/.cache/huggingface"
TRANSFORMERS_CACHE = "/app/.cache/huggingface"
TOKENIZERS_PARALLELISM = "false"
